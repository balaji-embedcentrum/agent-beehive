# SwarmHQ Environment Variables

# Database
POSTGRES_USER=swarmhq
POSTGRES_PASSWORD=changeme
POSTGRES_DB=swarmhq
DATABASE_URL=postgresql+asyncpg://swarmhq:changeme@postgres:5432/swarmhq

# Redis
REDIS_URL=redis://redis:6379

# Auth (generate with: openssl rand -hex 32)
JWT_SECRET=changeme_generate_a_real_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Admin user (created on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=http://localhost:3000

# UI
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
